    "dotenv": "^16.4.5",
    "framer-motion": "^12.0.0",
    "lenis": "^1.1.0",
    "lucide-react": "latest",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "recharts": "^2.12.0",
    "tailwind-merge": "^2.5.0",
    "viem": "^2.48.0",
    "wagmi": "^2.19.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
