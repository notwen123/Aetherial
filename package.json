{
  "name": "aetherial",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "agents",
    "contracts",
    "frontend"
  ],
  "scripts": {
    "contracts:compile": "npm run compile -w @aetherial/contracts",
